<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Dino Remasterizado 🦖✨ (Sem Buracos)</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  body {
    margin: 0;
    background: #87CEEB;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    touch-action: manipulation;
  }
  canvas {
    border: 2px solid #222;
    background: linear-gradient(#87CEEB, #E0F6FF);
  }
</style>
</head>
<body>

<canvas id="gameCanvas"></canvas>

<script>
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

canvas.width = window.innerWidth * 0.95;
canvas.height = 250;

// ---------------------------
// VARIÁVEIS DO JOGO
// ---------------------------
let gameState = "start";
let score = 0;
let highScore = localStorage.getItem("highScore") || 0;
let speed = 6;

// ---------------------------
// DINO ANIMADO (PULO ALTO)
// ---------------------------
const dino = {
  x: 60,
  y: 180,
  width: 40,
  height: 45,
  velocityY: 0,
  gravity: 1.2,
  jumpPower: -24,
  isJumping: false,
  legFrame: 0,
  justJumped: false
};

// ---------------------------
// CÉU, NUVENS E CICLO DIA/NOITE
// ---------------------------
let skyColor = 0;
let cycle = 0;

let clouds = [];
for (let i = 0; i < 6; i++) {
  clouds.push({
    x: Math.random() * canvas.width,
    y: Math.random() * 80 + 10,
    speed: 0.5 + Math.random(),
    scale: 0.7 + Math.random() * 0.8
  });
}

// ---------------------------
// OBSTÁCULOS (SEM CACTOS E SEM BURACOS)
// ---------------------------
let obstacles = [];

function spawnObstacle() {
  const types = ["stoneSmall", "stoneMedium", "stoneLarge", "bush", "log"];
  const type = types[Math.floor(Math.random() * types.length)];

  const obs = {
    x: canvas.width + 20,
    type: type,
    width: 30,
    height: 30,
    counted: false
  };

  if (type === "stoneSmall") obs.height = 20;
  if (type === "stoneMedium") obs.height = 30;
  if (type === "stoneLarge") obs.height = 45;
  if (type === "bush") obs.height = 25;
  if (type === "log") obs.height = 35;

  obstacles.push(obs);
}

setInterval(() => {
  if (gameState === "playing") spawnObstacle();
}, 1400);

// ---------------------------
// SISTEMA DE MISSÕES 🏆
// ---------------------------
const missions = [
  { type: "distance", goal: 500 },
  { type: "distance", goal: 1500 },
  { type: "distance", goal: 3000 },
  { type: "obstacles", goal: 20 },
  { type: "obstacles", goal: 40 },
  { type: "jumps", goal: 15 },
  { type: "survive", goal: 30 },
  { type: "survive", goal: 60 },
  { type: "night", goal: 1 },
  { type: "day", goal: 1 }
];

let currentMission = null;
let missionProgress = 0;
let missionCompleted = false;
let missionTimer = 0;

function pickMission() {
  currentMission = missions[Math.floor(Math.random() * missions.length)];
  missionProgress = 0;
  missionCompleted = false;
  missionTimer = 0;
}

pickMission();

// ---------------------------
// DESENHAR DINO
// ---------------------------
function drawDino() {
  const x = dino.x;
  const y = dino.y;

  ctx.fillStyle = "#2ecc71";
  ctx.beginPath();
  ctx.roundRect(x, y, 40, 30, 8);
  ctx.fill();

  ctx.beginPath();
  ctx.roundRect(x + 25, y - 20, 25, 25, 8);
  ctx.fill();

  ctx.fillStyle = "white";
  ctx.beginPath();
  ctx.arc(x + 42, y - 8, 4, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = "black";
  ctx.beginPath();
  ctx.arc(x + 42, y - 8, 2, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = "#27ae60";
  const legOffset = dino.legFrame < 10 ? 0 : 6;

  ctx.fillRect(x + 8, y + 28 + legOffset, 8, 15);
  ctx.fillRect(x + 24, y + 28 - legOffset, 8, 15);

  dino.legFrame = (dino.legFrame + 1) % 20;
}

// ---------------------------
// NUVENS
// ---------------------------
function drawClouds() {
  clouds.forEach(c => {
    ctx.fillStyle = "rgba(255,255,255,0.9)";
    ctx.beginPath();
    ctx.ellipse(c.x, c.y, 30 * c.scale, 15 * c.scale, 0, 0, Math.PI * 2);
    ctx.fill();

    c.x -= c.speed;
    if (c.x < -50) c.x = canvas.width + 50;
  });
}

// ---------------------------
// CICLO DIA/NOITE
// ---------------------------
function updateSky() {
  cycle += 0.002;
  skyColor = (Math.sin(cycle) + 1) / 2;

  const r = 135 - skyColor * 100;
  const g = 206 - skyColor * 150;
  const b = 235 - skyColor * 200;

  canvas.style.background = `linear-gradient(rgb(${r},${g},${b}), #E0F6FF)`;
}

// ---------------------------
// DESENHAR OBSTÁCULOS
// ---------------------------
function drawObstacle(obs) {
  if (obs.type.includes("stone")) {
    ctx.fillStyle = "#6e6e6e";
    ctx.beginPath();
    ctx.ellipse(obs.x, 200 - obs.height / 2, obs.width, obs.height / 2, 0, 0, Math.PI * 2);
    ctx.fill();
  }

  if (obs.type === "bush") {
    ctx.fillStyle = "#2ecc71";
    ctx.beginPath();
    ctx.ellipse(obs.x, 200 - obs.height / 2, 25, 15, 0, 0, Math.PI * 2);
    ctx.fill();
  }

  if (obs.type === "log") {
    ctx.fillStyle = "#8b4513";
    ctx.fillRect(obs.x - 25, 200 - obs.height, 50, 15);
  }
}

// ---------------------------
// COLISÃO
// ---------------------------
function checkCollision(obs) {
  return (
    dino.x < obs.x + obs.width &&
    dino.x + dino.width > obs.x &&
    dino.y + dino.height > 200 - obs.height
  );
}

// ---------------------------
// MISSÕES
// ---------------------------
function updateMission() {
  if (!currentMission || missionCompleted) return;

  if (currentMission.type === "distance") {
    missionProgress = score;
    if (missionProgress >= currentMission.goal) completeMission();
  }

  if (currentMission.type === "obstacles") {
    obstacles.forEach(o => {
      if (o.x + 20 < dino.x && !o.counted) {
        o.counted = true;
        missionProgress++;
      }
    });
    if (missionProgress >= currentMission.goal) completeMission();
  }

  if (currentMission.type === "jumps") {
    if (dino.justJumped) {
      missionProgress++;
      dino.justJumped = false;
    }
    if (missionProgress >= currentMission.goal) completeMission();
  }

  if (currentMission.type === "survive") {
    missionTimer += 1 / 60;
    missionProgress = Math.floor(missionTimer);
    if (missionProgress >= currentMission.goal) completeMission();
  }

  if (currentMission.type === "night" && skyColor > 0.8) completeMission();
  if (currentMission.type === "day" && skyColor < 0.2) completeMission();
}

function completeMission() {
  missionCompleted = true;
  score += 500;
  setTimeout(() => pickMission(), 3000);
}

// ---------------------------
// INTERFACE DAS MISSÕES
// ---------------------------
function drawMissionUI() {
  if (!currentMission) return;

  ctx.fillStyle = "black";
  ctx.font = "16px Arial";

  ctx.fillText("Missão:", canvas.width - 200, 30);

  let text = "";

  if (currentMission.type === "distance")
    text = `Corra ${currentMission.goal}m`;

  if (currentMission.type === "obstacles")
    text = `Desvie de ${currentMission.goal} obstáculos`;

  if (currentMission.type === "jumps")
    text = `Dê ${currentMission.goal} pulos`;

  if (currentMission.type === "survive")
    text = `Sobreviva ${currentMission.goal}s`;

  if (currentMission.type === "night")
    text = `Chegue à noite`;

  if (currentMission.type === "day")
    text = `Chegue ao dia`;

  ctx.fillText(text, canvas.width - 200, 55);

  if (!missionCompleted) {
    ctx.fillText(
      `Progresso: ${missionProgress} / ${currentMission.goal}`,
      canvas.width - 200,
      80
    );
  } else {
    ctx.fillStyle = "green";
    ctx.font = "20px Arial";
    ctx.fillText("✅ MISSÃO COMPLETA!", canvas.width - 220, 80);
  }
}

// ---------------------------
// LOOP DO JOGO
// ---------------------------
function update() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  updateSky();
  drawClouds();

  ctx.fillStyle = "#333";
  ctx.fillRect(0, 210, canvas.width, 40);

  obstacles.forEach(obs => {
    drawObstacle(obs);
    obs.x -= speed;

    if (checkCollision(obs)) {
      gameState = "gameover";
    }
  });

  obstacles = obstacles.filter(o => o.x > -50);

  drawDino();

  dino.velocityY += dino.gravity;
  dino.y += dino.velocityY;

  if (dino.y > 180) {
    dino.y = 180;
    dino.velocityY = 0;
    dino.isJumping = false;
  }

  if (gameState === "playing") {
    score++;
    updateMission();

    ctx.fillStyle = "black";
    ctx.font = "20px Arial";
    ctx.fillText("Score: " + score, 20, 30);
    ctx.fillText("Recorde: " + highScore, 20, 55);

    drawMissionUI();
  }

  if (gameState === "start") {
    ctx.fillStyle = "black";
    ctx.font = "28px Arial";
    ctx.fillText("Toque para começar", canvas.width / 2 - 120, 120);
  }

  if (gameState === "gameover") {
    ctx.fillStyle = "red";
    ctx.font = "30px Arial";
    ctx.fillText("GAME OVER", canvas.width / 2 - 90, 120);

    if (score > highScore) {
      highScore = score;
      localStorage.setItem("highScore", highScore);
    }
  }

  requestAnimationFrame(update);
}

update();

// ---------------------------
// CONTROLES
// ---------------------------
window.addEventListener("pointerdown", () => {
  if (gameState === "start") {
    gameState = "playing";
    return;
  }
  if (gameState === "gameover") {
    obstacles = [];
    score = 0;
    dino.y = 180;
    pickMission();
    gameState = "playing";
    return;
  }
  if (!dino.isJumping) {
    dino.velocityY = dino.jumpPower;
    dino.isJumping = true;
    dino.justJumped = true;
  }
});
</script>

</body>
</html>
